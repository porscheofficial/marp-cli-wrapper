    "tar-fs": "^3.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
